{
  "name": "fine-bundle-test",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.core-preload.config.ts --port 3344",
    "build:default": "vite build --config vite.default.config.ts",
    "build:core-preload": "vite build --config vite.core-preload.config.ts",
    "build:core-resolve": "vite build --config vite.core-resolve.config.ts",
    "build": "pnpm run build:core-preload",
    "build:all": "pnpm run build:default && pnpm run build:core-preload && pnpm run build:core-resolve",
    "verify:default": "node ./scripts/verify-bundle.mjs default",
    "verify:core-preload": "node ./scripts/verify-bundle.mjs core-preload",
    "verify:core-resolve": "node ./scripts/verify-bundle.mjs core-resolve",
    "verify:all": "pnpm run verify:default && pnpm run verify:core-preload && pnpm run verify:core-resolve",
    "build:verify": "pnpm run build:all && pnpm run verify:all"
  },
  "dependencies": {
    "@cmshiki/shiki": "workspace:*",
    "@codemirror/state": "catalog:",
    "@codemirror/view": "catalog:",
    "@shikijs/langs": "3.21.0",
    "@shikijs/themes": "3.21.0",
    "shiki": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
