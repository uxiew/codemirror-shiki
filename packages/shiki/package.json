  "license": "MIT",
  "homepage": "https://github.com/uxiew/codemirror-shiki#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uxiew/codemirror-shiki.git",
    "directory": "packages/shiki"
  },
