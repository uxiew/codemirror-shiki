{
  "name": "@cmshiki/utils",
  "version": "0.2.0",
  "description": "Utilities for CodeMirror",
  "license": "MIT",
  "homepage": "https://github.com/uxiew/codemirror-shiki#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uxiew/codemirror-shiki.git",
    "directory": "packages/utils"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "codemirror",
    "codemirror-shiki",
    "codemirror-utils",
